{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/bfhl",            "dest": "/api/index.js" },
    { "src": "/actuator/health", "dest": "/api/index.js" },
    { "src": "/actuator/info",   "dest": "/api/index.js" },
    { "src": "/(.*)",            "dest": "/api/index.js" }
  ]
}
